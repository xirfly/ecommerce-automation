# 数据库配置
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/ecommerce_automation
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_USER_PASSWORD=your_user_password
MYSQL_REPL_PASSWORD=your_repl_password
MYSQL_MASTER_HOST=master_host_ip

# Redis配置
REDIS_URL=redis://:your_redis_password@localhost:6379/0
REDIS_PASSWORD=your_redis_password

# JWT配置
JWT_SECRET_KEY=your-secret-key-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenClaw配置
OPENCLAW_API_URL=http://localhost:3000
OPENCLAW_API_KEY=your_openclaw_api_key

# 飞书配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# AI服务配置（二期）
OPENAI_API_KEY=your_openai_api_key
MIDJOURNEY_API_KEY=your_midjourney_api_key
RUNWAY_API_KEY=your_runway_api_key

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/ecommerce/app.log

# Celery配置
CELERY_BROKER_URL=redis://:your_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password@localhost:6379/2
CELERY_WORKER_CONCURRENCY=4

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
